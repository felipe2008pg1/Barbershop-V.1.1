services:
  - type: web
    name: barbershop-api
    runtime: python
    buildCommand: pip install -r requirements.txt
    startCommand: uvicorn app.main:app --host 0.0.0.0 --port $PORT
    envVars:
      - key: SUPABASE_URL
        sync: false
      - key: SUPABASE_SERVICE_ROLE_KEY
        sync: false
      - key: SUPABASE_ANON_KEY
        sync: false
      - key: SUPABASE_JWT_SECRET
        sync: false
      - key: ADMIN_API_KEY
        sync: false
      - key: CORS_ALLOWED_ORIGINS
        sync: false
      - key: DEBUG_LOGGING
        value: false
      - key: RATE_LIMIT_BOOKING
        value: 5/minute
      - key: RATE_LIMIT_LOOKUP
        value: 10/minute
      - key: RATE_LIMIT_LOGIN
        value: 10/minute
