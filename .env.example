# Copy this file to ".env" and fill in your real Supabase project values.
# NEVER commit the ".env" file to GitHub.

# Supabase Dashboard > Project Settings > API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
SUPABASE_ANON_KEY=your_anon_key_here

# Supabase Dashboard > Project Settings > API > JWT Settings > JWT Secret
SUPABASE_JWT_SECRET=your_jwt_secret_here

# A secret string you create yourself (any long random value).
# This is the password used to access the admin panel.
ADMIN_API_KEY=set_a_strong_key_here

# ---------- Optional: security & performance settings ----------
# Comma-separated list of allowed origins for browser requests.
# Defaults to "*" (any origin) if not set — fine for local development,
# but should be restricted to your real domain(s) in production.
# Example: CORS_ALLOWED_ORIGINS=https://mybarbershop.com,https://www.mybarbershop.com
CORS_ALLOWED_ORIGINS=*

# Set to "true" for verbose debug logging during local development.
DEBUG_LOGGING=false

# Rate limits (requests per time window) for sensitive endpoints.
# Format follows the `limits` library syntax, e.g. "5/minute", "100/hour".
RATE_LIMIT_BOOKING=5/minute
RATE_LIMIT_LOOKUP=10/minute
RATE_LIMIT_LOGIN=10/minute